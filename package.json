{
  "name": "astronautiste-web",
  "version": "1.0.0",
  "private": true,
  "description": "Astronautisté — promo landing (Zola + Flowbite)",
  "scripts": {
    "build:css": "tailwindcss -i ./styles/input.css -o ./static/css/main.css --minify",
    "watch:css": "tailwindcss -i ./styles/input.css -o ./static/css/main.css --watch",
    "build": "bash scripts/build.sh",
    "check": "bash scripts/check.sh",
    "serve": "bash scripts/serve.sh",
    "dev": "bash scripts/serve.sh",
    "test:e2e": "playwright test",
    "test:e2e:mobile": "playwright test --project=mobile-chrome",
    "test:e2e:live": "playwright test --config=playwright.live.config.ts"
  },
  "devDependencies": {
    "@alpinejs/intersect": "^3.14.8",
    "@playwright/test": "^1.49.0",
    "@tailwindcss/typography": "^0.5.19",
    "alpinejs": "^3.14.8",
    "autoprefixer": "^10.4.20",
    "flowbite": "^2.5.2",
    "p5": "^1.11.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  }
}
